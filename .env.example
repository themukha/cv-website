# Database settings for Umami analytics
DB_NAME=umami
DB_USER=umami_user
DB_PASSWORD=your_secure_database_password_here

# Umami session secret (any long random string)
UMAMI_APP_SECRET=your_random_string_for_security_123

# Your website data (from Umami Cloud or your own server)
# Note: The application uses UMAMI_ID and UMAMI_URL environment variables
UMAMI_ID=your-website-id-here
UMAMI_URL=https://your-umami-instance.com
